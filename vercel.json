{
    "version": 2,
    "env": {
        "API_URL": "https://alumni-backend-9qt9.onrender.com"
    },
    "builds": [
        {
            "src": "build.sh",
            "use": "@vercel/static-build",
            "config": {
                "distDir": "build/web"
            }
        }
    ],
    "routes": [
        {
            "src": "/((?!.*\\..*).*)",
            "dest": "/index.html"
        }
    ]
}